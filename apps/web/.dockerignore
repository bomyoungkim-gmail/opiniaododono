# ─── Build artefacts ─────────────────────────────────────────────────────────
.next/
out/
build/

# ─── Dependencies (instaladas dentro do container) ───────────────────────────
node_modules/

# ─── Environment (nunca incluir .env no contexto do build) ───────────────────
.env
.env.*
!.env.local.example

# ─── Git ─────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ─── Documentação e planos (não necessários na imagem) ───────────────────────
*.md
docs/

# ─── Logs e debug ────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ─── Sistema operacional ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── Testing ─────────────────────────────────────────────────────────────────
coverage/
__tests__/
*.test.ts
*.spec.ts
